# Portfolio Platform - Production Environment Variables Template
# ==============================================================
# Copy this file to .env.production and fill in the values.
# DO NOT commit this file with actual secrets to version control.
#
# How to obtain each variable:
# ---------------------------

# ==========================================
# DATABASE (Neon PostgreSQL)
# ==========================================
# Sign up at https://neon.tech and create a project.
# Connection string format:
#   postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/portfolio_v2_prod?sslmode=require

SPRING_DATASOURCE_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/portfolio_v2_prod?sslmode=require
SPRING_DATASOURCE_USERNAME=your_neon_username
SPRING_DATASOURCE_PASSWORD=your_neon_password


# ==========================================
# GOOGLE OAUTH2
# ==========================================
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID credentials
# 3. Set authorized redirect URIs:
#    - https://your-domain.com/api/v1/auth/oauth2/callback/google
#    - https://your-domain.api.neon.tech/api/v1/auth/oauth2/callback/google
# 4. Add your domains to "Authorized JavaScript origins"

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ==========================================
# JWT SECURITY
# ==========================================
# Generate a secure 64+ character random string:
#   openssl rand -base64 48 | tr -d '\n'
# Or use: https://generate-secret.vercel.app/64

JWT_SECRET_KEY=your-64-character-minimum-random-string-here


# ==========================================
# CORS
# ==========================================
# Production frontend domains (comma-separated, no spaces)
# Examples:
#   - Vercel: https://portfolio-fe.vercel.app
#   - Custom domain: https://portfolio-v2.com

CORS_ALLOWED_ORIGINS=https://portfolio-fe.vercel.app


# ==========================================
# GITHUB WEBHOOK (Optional)
# ==========================================
# Generate a random secret for webhook verification:
#   openssl rand -hex 32

GITHUB_WEBHOOK_SECRET=your-github-webhook-secret


# ==========================================
# SPRING PROFILE
# ==========================================
SPRING_PROFILES_ACTIVE=prod
