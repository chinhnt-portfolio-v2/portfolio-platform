{
  "name": "portfolio-platform-smoke-tests",
  "version": "1.0.0",
  "description": "Smoke tests for portfolio-platform CI gate — REST and WebSocket integration tests",
  "private": true,
  "scripts": {
    "smoke:test": "jest --config jest.smoke.config.js",
    "smoke:test:rest": "jest --config jest.smoke.config.js --testPathPattern=rest",
    "smoke:test:ws": "jest --config jest.smoke.config.js --testPathPattern=websocket"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.14",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "ws": "^8.18.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
